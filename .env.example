# V Platform environment configuration
# Copy this to .env and fill in your keys

# Choose primary LLM provider: "anthropic" (recommended) or "openai"
LLM_PROVIDER=anthropic

# API keys (only the one for your chosen provider is required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Models (override defaults if needed)
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o

# Orchestrator behavior
V_ORCHESTRATOR_MAX_ITERATIONS=2
V_ORCHESTRATOR_QUALITY_THRESHOLD=0.8

# Optional: LangSmith tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=v-platform
